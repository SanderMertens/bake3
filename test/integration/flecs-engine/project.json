{
    "id": "flecs_engine",
    "type": "application",
    "value": {
        "language": "c",
        "defines": ["FLECS_SCRIPT_MATH"],
        "${os Darwin}": {
            "defines": ["GLFW_EXPOSE_NATIVE_COCOA"],
            "ldflags": ["-framework Cocoa", "-framework QuartzCore", "-framework IOKit", "-framework Foundation"]
        }
    },
    "lang.c": {
        "c-standard": "c11"
    },
    "lang.cpp": {
        "cpp-standard": "c++11"
    },
    "bundle": {
        "glfw": {
            "repository": "https://github.com/glfw/glfw.git",
            "tag": "3.3.9",
            "library": "glfw3",
            "cmake-args": [
                "-DGLFW_BUILD_DOCS=OFF",
                "-DGLFW_BUILD_TESTS=OFF",
                "-DGLFW_BUILD_EXAMPLES=OFF"
            ]
        },
        "cglm": {
            "repository": "https://github.com/recp/cglm.git",
            "tag": "v0.9.2",
            "library": "cglm",
            "cmake-args": [
                "-DCGLM_SHARED=OFF",
                "-DCGLM_STATIC=ON"
            ]
        },
        "flecs": {
            "repository": "https://github.com/SanderMertens/flecs.git",
            "branch": "master",
            "library": "flecs_static",
            "cmake-args": [
                "-DFLECS_SHARED=OFF",
                "-DFLECS_PIC=ON",
                "-DCMAKE_C_FLAGS=-DFLECS_SCRIPT_MATH",
                "-DCMAKE_CXX_FLAGS=-DFLECS_SCRIPT_MATH"
            ]
        },
        "stb": {
            "repository": "https://github.com/nothings/stb.git",
            "commit": "28d546d5eb77d4585506a20480f4de2e706dff4c",
            "header-only": true
        },
        "cgltf": {
            "repository": "https://github.com/jkuhlmann/cgltf.git",
            "tag": "v1.15",
            "header-only": true
        },
        "tinyexr": {
            "repository": "https://github.com/syoyo/tinyexr.git",
            "tag": "v1.0.9",
            "header-only": true,
            "include": [".", "deps/miniz"],
            "sources": ["deps/miniz/miniz.c"]
        },
        "wgpu_native": {
            "repository": "https://github.com/gfx-rs/wgpu-native.git",
            "tag": "v27.0.4.0",
            "build-system": "cargo",
            "library": "wgpu_native",
            "include": ["ffi", "ffi/webgpu-headers"]
        }
    }
}
